# 이 파일을 복사해서 .env로 저장한 뒤 실제 값을 채워 넣으세요.
# .env 파일은 절대 깃허브 등에 올리지 마세요 (이미 .gitignore에 포함됨).

# Google Gemini API 키 — https://aistudio.google.com (Google AI Studio) → Get API key 에서 발급
# 없으면 AI 분석 기능(자연어 질의, AI 종합답변)이 비활성화되고, DB 검색은 그대로 작동합니다.
GEMINI_API_KEY=여기에-실제-Gemini-API-키-입력

# 사용할 Gemini 모델 (선택, 기본값 gemini-3.5-flash — 2026.7 기준 권장 모델)
GEMINI_MODEL=gemini-3.5-flash

# law.go.kr Open API 인증키(OC) — open.law.go.kr 마이페이지 → API인증키관리 에서 확인
# 없으면 조문 정밀 링크 대신 법령 검색결과 링크로 동작합니다(깨진 링크는 없음).
LAW_OC=7788

# 서버 포트 (선택, 기본값 3000)
PORT=3000
